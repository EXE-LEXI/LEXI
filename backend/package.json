{
  "name": "lexi-backend",
  "version": "0.0.1",
  "description": "LEXI Project - NestJS Backend",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/*.test.js\" \"prisma/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "seed": "nest build && node dist/prisma/seed.js",
    "test": "npm run build && node --test test/*.test.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix"
  },
  "dependencies": {
    "@nestjs/axios": "^3.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^7.4.2",
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "cheerio": "^1.0.0-rc.12",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cron": "^3.1.6",
    "firebase-admin": "^13.10.0",
    "openai": "^4.24.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "playwright": "^1.40.0",
    "reflect-metadata": "^0.1.13",
    "rss-parser": "^3.13.0",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cheerio": "^0.22.0",
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/xml2js": "^0.4.11",
    "eslint": "^8.42.0",
    "prettier": "^2.8.8",
    "prisma": "^5.22.0",
    "typescript": "^5.1.3"
  },
  "prisma": {
    "seed": "npm run seed"
  }
}
