# Database connection
MONGODB_URI="mongodb+srv://USER:PASSWORD@HOST/Lexi"

# App settings
PORT=3000
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Auth secrets
JWT_SECRET=lexi_access_token_secret_change_me
JWT_REFRESH_SECRET=lexi_refresh_token_secret_change_me

# Supabase (optional)
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_key

# Firebase Cloud Messaging
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_PATH=
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
FCM_DAILY_REMINDER_HOUR=20

# AI draft generation
AI_DRAFT_PROVIDER=local
AI_DRAFT_ENDPOINT=
AI_DRAFT_API_KEY=
AI_DRAFT_MODEL=
AI_DRAFT_PROMPT_VERSION=legal-draft-v1

# Video storage
# local = dev only, cloudinary = production-ready public video storage
VIDEO_STORAGE_PROVIDER=local
PUBLIC_API_URL=http://localhost:3000
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_VIDEO_FOLDER=lexi/videos

# Legal source crawler
LEGAL_CRAWL_MAX_TEXT_LENGTH=250000
LEGAL_SOURCE_CRAWL_ENABLED=false
LEGAL_SOURCE_CRAWL_CRON=0 2 * * *
LEGAL_SOURCE_CRAWL_URLS=
LEGAL_SOURCE_CRAWL_MODULE_ID=
LEGAL_SOURCE_CRAWL_QUESTION_COUNT=3

# Automated legal pipeline
LEGAL_AUTO_PIPELINE_ENABLED=false
LEGAL_AUTO_PIPELINE_BOOTSTRAP=false
LEGAL_AUTO_PIPELINE_MAX_URLS_PER_SOURCE=50
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
