# Database connection
DATABASE_URL="postgresql://postgres:123456@localhost:5432/lexi_db?schema=public"

# App settings
PORT=3000
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Auth secrets
JWT_SECRET=lexi_access_token_secret_change_me
JWT_REFRESH_SECRET=lexi_refresh_token_secret_change_me

# Supabase (Optional for Phase 1)
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_key

# Firebase Cloud Messaging
# Production should prefer FIREBASE_SERVICE_ACCOUNT_JSON or the three FCM_* fields
# from a secret manager. FIREBASE_SERVICE_ACCOUNT_PATH is useful for mounted secrets.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_PATH=
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
FCM_DAILY_REMINDER_HOUR=20

# AI draft generation
# AI_DRAFT_PROVIDER=local keeps deterministic local generation.
# For OpenAI-compatible providers, set provider to openai-compatible and supply endpoint/model/key.
AI_DRAFT_PROVIDER=local
AI_DRAFT_ENDPOINT=
AI_DRAFT_API_KEY=
AI_DRAFT_MODEL=
AI_DRAFT_PROMPT_VERSION=legal-draft-v1
