datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// ENUMS
// ==========================================

enum UserRole {
  ADMIN
  LEARNER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum LessonReviewStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  ARCHIVED
}

enum BadgeCriteriaType {
  FIRST_LESSON
  THREE_LESSONS
  PERFECT_SCORE
  FIVE_ATTEMPTS
  SEVEN_DAY_STREAK
}

enum DailyChallengeType {
  COMPLETE_LESSONS
}

enum DeviceTokenPlatform {
  ANDROID
  IOS
  WEB
}

enum NotificationDeliveryType {
  DAILY_REMINDER
  STREAK_REMINDER
  REVIEW_REMINDER
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  PARTIAL
  FAILED
}

enum LegalSourceCrawlStatus {
  PENDING
  CRAWLED
  FAILED
  ARCHIVED
}

enum AiGenerationType {
  LESSON
  QUIZ
  VIDEO_SCRIPT
  FULL_LESSON_PACKAGE
}

enum AiGenerationStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum LessonDraftStatus {
  DRAFT
  IN_REVIEW
  ACCEPTED
  REJECTED
}

enum MediaAssetType {
  VIDEO
}

enum MediaAssetSourceType {
  EXTERNAL_URL
  RENDER_REQUEST
}

enum MediaAssetStatus {
  DRAFT
  RENDERING
  READY
  FAILED
  ARCHIVED
}

enum MediaAssetPlacement {
  LESSON_RESOURCE
  SHORTS
}

enum FeedbackReportCategory {
  CONTENT_ISSUE
  LEGAL_CORRECTION
  BUG
  SUGGESTION
  OTHER
}

enum FeedbackReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}

enum RewardTransactionType {
  EARN
  SPEND
  ADJUST
  EXPIRE
}

enum RewardSource {
  QUIZ
  GAME
  DAILY_CHALLENGE
  ADMIN
  REDEMPTION
}

enum VoucherCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
}

enum VoucherRedemptionStatus {
  PENDING
  FULFILLED
  CANCELLED
}

// ==========================================
// USER MODELS
// ==========================================

model User {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  email        String     @unique
  passwordHash String
  role         UserRole   @default(LEARNER)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  profile                UserProfile?
  attempts               LessonAttempt[]
  progress               UserProgress[]
  refreshTokens          RefreshToken[]
  passwordResetTokens    PasswordResetToken[]
  badges                 UserBadge[]
  challenges             UserChallenge[]
  deviceTokens           DeviceToken[]
  notificationPreference NotificationPreference?
  notificationDeliveries NotificationDeliveryLog[]
  lessonNotes            LessonNote[]
  lessonDiscussions      LessonDiscussion[]
  lessonDiscussionReplies LessonDiscussionReply[]
  feedbackReports        FeedbackReport[]
  rewardAccount          RewardAccount?
  rewardLedgerEntries    RewardLedgerEntry[]
  voucherRedemptions     VoucherRedemption[]
  chatSession            ChatSession?

  @@map("users")
}

model RefreshToken {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  jti       String    @unique
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
  @@map("password_reset_tokens")
}

model UserProfile {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @unique @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName  String
  avatarUrl String?
  xp        Int     @default(0)
  streak    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_profiles")
}

// ==========================================
// CONTENT MODELS
// ==========================================

model Category {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  slug        String   @unique
  title       String
  description String?
  iconUrl     String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  modules LearningModule[]

  @@map("categories")
}

model LearningModule {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  categoryId String   @db.ObjectId
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  slug        String   @unique
  title       String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lessons          Lesson[]
  lessonDrafts     LessonDraft[]
  aiGenerationJobs AiGenerationJob[]

  @@index([categoryId])
  @@map("learning_modules")
}

model Lesson {
  id       String         @id @default(auto()) @map("_id") @db.ObjectId
  moduleId String         @db.ObjectId
  module   LearningModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  slug            String             @unique
  title           String
  content         String?
  videoUrl        String?
  sourceTitle     String?
  sourceUrl       String?
  legalDocumentNo String?
  effectiveDate   DateTime?
  reviewedAt      DateTime?
  reviewerNote    String?
  sortOrder       Int                @default(0)
  isActive        Boolean            @default(true)
  reviewStatus    LessonReviewStatus @default(DRAFT)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  questions    QuizQuestion[]
  attempts     LessonAttempt[]
  progress     UserProgress[]
  sourceDrafts LessonDraft[]
  mediaAssets  MediaAsset[]
  notes        LessonNote[]
  discussions  LessonDiscussion[]

  @@index([moduleId])
  @@map("lessons")
}

model LegalSourceDocument {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  title           String
  sourceUrl       String?   @unique
  legalDocumentNo String?
  effectiveDate   DateTime?
  issuedDate      DateTime?
  issuedBy        String?

  rawText        String
  normalizedText String?
  contentHash    String?   @unique
  crawlStatus    LegalSourceCrawlStatus @default(CRAWLED)
  crawledAt      DateTime?

  // AI Processing fields
  legalCategory   String?   // CIVIL_LAW, CRIMINAL_LAW, etc.
  keywords        String[]  // Array of keywords
  summary         String?
  keyPhrases      String[]  // Array of key phrases
  isProcessedByAI Boolean   @default(false)

  // Tracking
  crawlJobId      String?
  sourceType      String?   // RSS, SITEMAP, API, HYBRID
  createdBy       String    @default("SYSTEM_AUTO_CRAWLER")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  generationJobs AiGenerationJob[]
  lessonDrafts   LessonDraft[]

  @@index([crawlStatus])
  @@index([legalDocumentNo])
  @@index([legalCategory])
  @@index([crawlJobId])
  @@map("legal_source_documents")
}

model AiGenerationJob {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  sourceDocumentId String              @db.ObjectId
  sourceDocument   LegalSourceDocument @relation(fields: [sourceDocumentId], references: [id], onDelete: Cascade)

  targetModuleId String?         @db.ObjectId
  targetModule   LearningModule? @relation(fields: [targetModuleId], references: [id], onDelete: SetNull)

  type          AiGenerationType   @default(FULL_LESSON_PACKAGE)
  status        AiGenerationStatus @default(PENDING)
  promptVersion String             @default("legal-draft-v1")
  model         String             @default("local-structured-generator")
  inputSnapshot Json?
  output        Json?
  errorMessage  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  drafts LessonDraft[]

  @@index([sourceDocumentId])
  @@index([targetModuleId])
  @@index([status])
  @@index([type])
  @@map("ai_generation_jobs")
}

model LessonDraft {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  generationJobId String?          @db.ObjectId
  generationJob   AiGenerationJob? @relation(fields: [generationJobId], references: [id], onDelete: SetNull)

  sourceDocumentId String              @db.ObjectId
  sourceDocument   LegalSourceDocument @relation(fields: [sourceDocumentId], references: [id], onDelete: Cascade)

  moduleId String?         @db.ObjectId
  module   LearningModule? @relation(fields: [moduleId], references: [id], onDelete: SetNull)

  createdLessonId String? @db.ObjectId
  createdLesson   Lesson? @relation(fields: [createdLessonId], references: [id], onDelete: SetNull)

  title        String
  content      String
  videoScript  String?
  videoPrompt  String?
  reviewerNote String?
  status       LessonDraftStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questions   LessonDraftQuestion[]
  mediaAssets MediaAsset[]

  @@index([generationJobId])
  @@index([sourceDocumentId])
  @@index([moduleId])
  @@index([status])
  @@map("lesson_drafts")
}

model LessonDraftQuestion {
  id      String      @id @default(auto()) @map("_id") @db.ObjectId
  draftId String      @db.ObjectId
  draft   LessonDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  questionText String
  explanation  String?
  sortOrder    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  options LessonDraftOption[]

  @@index([draftId])
  @@map("lesson_draft_questions")
}

model LessonDraftOption {
  id         String              @id @default(auto()) @map("_id") @db.ObjectId
  questionId String              @db.ObjectId
  question   LessonDraftQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  optionText String
  isCorrect  Boolean @default(false)
  sortOrder  Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([questionId])
  @@map("lesson_draft_options")
}

model MediaAsset {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  lessonId String? @db.ObjectId
  lesson   Lesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  draftId String?      @db.ObjectId
  draft   LessonDraft? @relation(fields: [draftId], references: [id], onDelete: SetNull)

  title        String?
  assetType    MediaAssetType       @default(VIDEO)
  sourceType   MediaAssetSourceType @default(EXTERNAL_URL)
  placement    MediaAssetPlacement  @default(LESSON_RESOURCE)
  status       MediaAssetStatus     @default(DRAFT)
  url          String?
  mimeType     String?
  provider     String?
  renderPrompt String?
  metadata     Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lessonId])
  @@index([draftId])
  @@index([assetType])
  @@index([sourceType])
  @@index([placement])
  @@index([status])
  @@map("media_assets")
}

model FeedbackReport {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  category FeedbackReportCategory
  status   FeedbackReportStatus   @default(OPEN)

  subject  String
  message  String
  pagePath String?
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([category])
  @@index([status])
  @@index([createdAt])
  @@map("feedback_reports")
}

model RewardAccount {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @unique @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  balance        Int @default(0)
  lifetimeEarned Int @default(0)
  lifetimeSpent  Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reward_accounts")
}

model RewardLedgerEntry {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type          RewardTransactionType
  source        RewardSource
  amount        Int
  balanceAfter  Int
  referenceId   String?
  idempotencyKey String @unique
  metadata      Json?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([source, createdAt])
  @@index([referenceId])
  @@map("reward_ledger_entries")
}

model RewardRule {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  code        String       @unique
  source      RewardSource
  title       String
  description String?
  points      Int
  dailyCap    Int?
  isActive    Boolean      @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([source])
  @@index([isActive])
  @@map("reward_rules")
}

model VoucherCampaign {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  title       String
  description String?
  costCoins   Int
  stock       Int?
  status      VoucherCampaignStatus @default(DRAFT)
  startsAt    DateTime?
  endsAt      DateTime?
  metadata    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  redemptions VoucherRedemption[]

  @@index([status])
  @@index([startsAt])
  @@index([endsAt])
  @@map("voucher_campaigns")
}

model VoucherRedemption {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  userId     String @db.ObjectId
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaignId String @db.ObjectId
  campaign   VoucherCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  costCoins Int
  status    VoucherRedemptionStatus @default(PENDING)
  code      String?
  note      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, campaignId])
  @@index([userId, createdAt])
  @@index([campaignId])
  @@index([status])
  @@map("voucher_redemptions")
}

// ==========================================
// QUIZ MODELS
// ==========================================

model QuizQuestion {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  lessonId String @db.ObjectId
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  questionText String
  explanation  String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  options     QuizOption[]
  userAnswers UserAnswer[]

  @@index([lessonId])
  @@map("quiz_questions")
}

model QuizOption {
  id         String       @id @default(auto()) @map("_id") @db.ObjectId
  questionId String       @db.ObjectId
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  optionText String
  isCorrect  Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userAnswers UserAnswer[]

  @@index([questionId])
  @@map("quiz_options")
}

// ==========================================
// TRACKING MODELS
// ==========================================

model LessonAttempt {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  userId   String @db.ObjectId
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId String @db.ObjectId
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  score          Int       @default(0)
  totalQuestions Int       @default(0)
  correctAnswers Int       @default(0)
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  answers UserAnswer[]

  @@index([userId])
  @@index([lessonId])
  @@map("lesson_attempts")
}

model UserAnswer {
  id               String        @id @default(auto()) @map("_id") @db.ObjectId
  attemptId        String        @db.ObjectId
  attempt          LessonAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId       String        @db.ObjectId
  question         QuizQuestion  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOptionId String        @db.ObjectId
  selectedOption   QuizOption    @relation(fields: [selectedOptionId], references: [id], onDelete: Cascade)

  isCorrect Boolean
  createdAt DateTime @default(now())

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
  @@map("user_answers")
}

model UserProgress {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  userId   String @db.ObjectId
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId String @db.ObjectId
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  status      ProgressStatus @default(NOT_STARTED)
  lastScore   Int?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@map("user_progress")
}

model LessonNote {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  userId   String @db.ObjectId
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId String @db.ObjectId
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  text             String
  videoTimeSeconds Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, lessonId])
  @@index([lessonId])
  @@map("lesson_notes")
}

model LessonDiscussion {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  userId   String @db.ObjectId
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId String @db.ObjectId
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  question String
  isSolved Boolean @default(false)

  replies   LessonDiscussionReply[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, lessonId])
  @@index([lessonId])
  @@index([isSolved])
  @@map("lesson_discussions")
}

model LessonDiscussionReply {
  id           String           @id @default(auto()) @map("_id") @db.ObjectId
  discussionId String           @db.ObjectId
  discussion   LessonDiscussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  userId       String           @db.ObjectId
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  body       String
  isAccepted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([discussionId])
  @@index([userId])
  @@map("lesson_discussion_replies")
}

model Badge {
  id           String            @id @default(auto()) @map("_id") @db.ObjectId
  code         String            @unique
  title        String
  description  String
  iconName     String
  criteriaType BadgeCriteriaType
  sortOrder    Int               @default(0)
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  users UserBadge[]

  @@map("badges")
}

model UserBadge {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId    String   @db.ObjectId
  badge      Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  unlockedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([badgeId])
  @@map("user_badges")
}

model DailyChallenge {
  id          String             @id @default(auto()) @map("_id") @db.ObjectId
  code        String             @unique
  title       String
  description String
  type        DailyChallengeType
  target      Int
  rewardXp    Int
  sortOrder   Int                @default(0)
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  users UserChallenge[]

  @@map("daily_challenges")
}

model UserChallenge {
  id               String         @id @default(auto()) @map("_id") @db.ObjectId
  userId           String         @db.ObjectId
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyChallengeId String         @db.ObjectId
  dailyChallenge   DailyChallenge @relation(fields: [dailyChallengeId], references: [id], onDelete: Cascade)
  challengeDate    DateTime
  progress         Int            @default(0)
  isCompleted      Boolean        @default(false)
  completedAt      DateTime?
  claimedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([userId, dailyChallengeId, challengeDate])
  @@index([userId])
  @@index([dailyChallengeId])
  @@index([challengeDate])
  @@map("user_challenges")
}

model DeviceToken {
  id         String              @id @default(auto()) @map("_id") @db.ObjectId
  userId     String              @db.ObjectId
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  token      String              @unique
  platform   DeviceTokenPlatform
  deviceId   String?
  appVersion String?
  lastSeenAt DateTime            @default(now())
  revokedAt  DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@index([userId])
  @@index([platform])
  @@index([revokedAt])
  @@map("device_tokens")
}

model NotificationPreference {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  userId                String   @unique @db.ObjectId
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyReminderEnabled  Boolean  @default(true)
  streakReminderEnabled Boolean  @default(true)
  reviewReminderEnabled Boolean  @default(true)
  reminderHour          Int      @default(20)
  timezone              String   @default("Asia/Bangkok")
  quietHoursStart       Int?
  quietHoursEnd         Int?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([timezone])
  @@map("notification_preferences")
}

model NotificationDeliveryLog {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        NotificationDeliveryType
  deliveryKey String
  status      NotificationDeliveryStatus @default(PENDING)
  title       String
  body        String
  data        Json?

  successCount Int       @default(0)
  failureCount Int       @default(0)
  deliveredAt  DateTime?
  readAt       DateTime?
  dismissedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, type, deliveryKey])
  @@index([type, deliveryKey])
  @@index([status])
  @@index([userId, readAt])
  @@index([userId, dismissedAt])
  @@map("notification_delivery_logs")
}

// ==========================================
// AUTOMATED PIPELINE MODELS
// ==========================================

model SourceRegistry {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  name            String   @unique
  description     String?
  sourceType      String   // RSS, SITEMAP, API, HYBRID

  // Configuration
  rssUrl          String?
  sitemapUrl      String?
  sitemapPattern  String?
  apiEndpoint     String?
  apiMethod       String   @default("GET")
  apiHeaders      Json?
  apiPageParam    String?  @default("page")
  apiLimitParam   String?  @default("limit")

  // Scheduling
  cronExpression  String?

  // Status
  status          String   @default("ACTIVE") // ACTIVE, DISABLED
  lastCrawlTime   DateTime @default(now())
  consecutiveFailures Int  @default(0)
  lastError       String?

  // Retry config
  maxRetries      Int      @default(3)
  retryDelayMs    Int      @default(5000)
  timeoutMs       Int      @default(30000)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String   @default("SYSTEM")

  crawlJobs CrawlJob[]

  @@index([status])
  @@index([cronExpression])
  @@index([updatedAt])
  @@map("source_registries")
}

model CrawlJob {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  sourceId        String   @db.ObjectId
  source          SourceRegistry @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  status          String   // PENDING, IN_PROGRESS, COMPLETED, FAILED
  startTime       DateTime @default(now())
  endTime         DateTime?

  discoveredCount Int      @default(0)
  crawledCount    Int      @default(0)
  validatedCount  Int      @default(0)
  aiProcessedCount Int     @default(0)
  persistedCount  Int      @default(0)
  errorCount      Int      @default(0)

  errorMessage    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sourceId])
  @@index([status])
  @@index([startTime])
  @@map("crawl_jobs")
}

model PipelineMetrics {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  date            DateTime @unique

  totalCrawls     Int      @default(0)
  successfulCrawls Int     @default(0)
  failedCrawls    Int      @default(0)
  docsCreated     Int      @default(0)
  docsUpdated     Int      @default(0)
  tokensUsed      Int      @default(0)
  estimatedCost   Float    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("pipeline_metrics")
}

model CrawlErrorLog {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  crawlJobId      String
  sourceId        String

  successfulCrawls Int     @default(0)
  failedCrawls    Int      @default(0)
  duplicatesDetected Int   @default(0)
  docsProcessedByAI Int    @default(0)
  docsPersisted   Int      @default(0)

  totalTokensUsed Int      @default(0)
  estimatedCost   Float    @default(0)
  averageCrawlTime Float   @default(0)
  averageAiProcessTime Float @default(0)

  status          String   // COMPLETED, FAILED
  lastError       String?
  durationMs      Int      @default(0)

  createdAt DateTime @default(now())

  @@index([crawlJobId])
  @@index([sourceId])
  @@index([createdAt])
  @@map("crawl_error_logs")
}

model AuditLog {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  entityType      String   // LegalSourceDocument, SourceRegistry, etc.
  entityId        String
  action          String   // CREATE, UPDATE, DELETE
  changes         Json?
  createdBy       String
  createdAt       DateTime @default(now())

  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ==========================================
// CHATBOT MODELS
// ==========================================

model ChatSession {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages  ChatMessage[]

  @@map("chat_sessions")
}

model ChatMessage {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  sessionId     String      @db.ObjectId
  session       ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role          String      // "user" or "model"
  content       String
  createdAt     DateTime    @default(now())

  @@index([sessionId])
  @@map("chat_messages")
}
